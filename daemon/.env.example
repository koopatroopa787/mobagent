# Copy to .env and fill in as needed.

LITELLM_PROXY_URL=http://localhost:4000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PAIRING_PORT=7890

# Absolute path to the local repo the daemon watches for failing tests.
# The daemon applies approved diffs here in an isolated git worktree.
REPO_PATH=

# Human-readable name sent to the phone after pairing (shown in the UI).
REPO_NAME=sample-todo-app

# Command the daemon runs in the worktree after applying a diff.
# Examples: "npm test", "pytest", "cargo test", "make test"
TEST_COMMAND=npm test
